rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Context helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint for User Profiles
    function isValidUserProfile(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 150
        && (!('careerGoal' in data) || (data.careerGoal is string && data.careerGoal.size() <= 2000))
        && (!('careerProfile' in data) || (data.careerProfile is string && data.careerProfile.size() <= 10000))
        && (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 200))
        && (!('streak' in data) || (data.streak is int && data.streak >= 0))
        && (!('points' in data) || (data.points is int && data.points >= 0))
        && (!('level' in data) || (data.level is int && data.level >= 0))
        && (!('badges' in data) || (data.badges is list && data.badges.size() <= 50));
    }

    // Validation Blueprint for Roadmaps
    function isValidRoadmap(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.milestones is list && data.milestones.size() <= 100;
    }

    // Validation Blueprint for ChatSessions
    function isValidChatSession(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 300
        && data.messages is list && data.messages.size() <= 500;
    }

    // Validation Blueprint for Feedback
    function isValidUserFeedback(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.rating is int && data.rating >= 1 && data.rating <= 5
        && (!('comment' in data) || (data.comment is string && data.comment.size() <= 2000));
    }

    // -- Collection: /users/{userId}
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data) && request.resource.data.email == request.auth.token.email;
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data) && request.resource.data.email == resource.data.email;
      allow delete: if false; // Users can never delete profiles via client SDK

      // -- Collection: /users/{userId}/roadmaps/{roadmapId}
      match /roadmaps/{roadmapId} {
        allow get: if isOwner(userId) && isValidId(roadmapId);
        allow create: if isOwner(userId) && isValidId(roadmapId) && isValidRoadmap(request.resource.data);
        allow update: if isOwner(userId) && isValidId(roadmapId) && isValidRoadmap(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(roadmapId);
      }

      // -- Collection: /users/{userId}/chats/{chatId}
      match /chats/{chatId} {
        allow get: if isOwner(userId) && isValidId(chatId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(chatId) && isValidChatSession(request.resource.data);
        allow update: if isOwner(userId) && isValidId(chatId) && isValidChatSession(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(chatId);
      }
    }

    // -- Collection: /feedback/{feedbackId}
    match /feedback/{feedbackId} {
      allow get: if isSignedIn() && isValidId(feedbackId);
      allow create: if isSignedIn() && isValidId(feedbackId) && isValidUserFeedback(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow list, update, delete: if false; // Feedback collection is write-only & admin-only readable (not in clients)
    }
  }
}
